CREATE DATABASE catalogo_peliculas;

USE catalogo_peliculas;

CREATE TABLE usuarios(
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100),
    email VARCHAR(100) UNIQUE,
    password VARCHAR(255)
);

CREATE TABLE peliculas(
    id INT AUTO_INCREMENT PRIMARY KEY,
    titulo VARCHAR(150),
    genero VARCHAR(100),
    anio INT,
    descripcion TEXT
);
